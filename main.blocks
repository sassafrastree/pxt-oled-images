lse if (charsetIndex.indexOf(text[i]) !== -1) {" line222="                for (let j = 0; j &lt; 11; j++) {" line223="                    for (let k = 0; k &lt; 8; k++) {" line224="                        if (charset[charsetIndex.indexOf(text[i])][j] &amp; (0x01 &lt;&lt; k)) {" line225="                            setPx(x + ((i - lineStart) * 8) + (8 - k), y + (line * 10) + j)" line226="                        }" line227="                    }" line228="                }" line229="            } else if (text[i].charCodeAt(0) &lt; 128 &amp;&amp; text[i].charCodeAt(0) &gt;= 32) {" line230="                for (let l = 0; l &lt; 11; l++) {" line231="                    for (let m = 0; m &lt; 8; m++) {" line232="                        if (font[text[i].charCodeAt(0) - 32][l] &amp; (0x01 &lt;&lt; m)) {" line233="                            setPx(x + ((i - lineStart) * 8) + (8 - m), y + (line * 10) + l)" line234="                        }" line235="                    }" line236="                }" line237="            } else {" line238="            }" line239="            basic.pause(1)" line240="        }" line241="        draw()" line242="    }" line243="    /**" line244="     * Draws image." line245="     * @param image image to draw (can be `images.createImage()` or image from extension `imageio`)" line246="     * @param x coordinate x of upper left corner of image (increases towards the right)" line247="     * @param y coordinate y of upper left corner of image (increases downwards)" line248="     */" line249="    //% block=&quot;draw image |$image|x $x|y $y&quot;" line250="    //% weight=100" line251="    export function drawImage(image: Image, x: number, y: number): void {" line252="        if ((image != null) &amp;&amp; (image != undefined)) {" line253="            let scale = 4" line254="            if (image.width() == 16) {" line255="                scale = 8" line256="            }" line257="            clear()" line258="            for (let img_y = 0; img_y &lt; image.width() * scale; img_y++) {" line259="                for (let img_x = 0; img_x &lt; image.height() * scale; img_x++) {" line260="                    let c = image.pixel(img_x, img_y)" line261="                    for (let y_scale = 0; y_scale &lt; scale; y_scale++) {" line262="                        for (let x_scale = 0; x_scale &lt; scale; x_scale++) {" line263="                            if (c) {" line264="                                setPx(x + img_x * scale - x_scale + scale, y + img_y * scale - y_scale + scale)" line265="                            }" line266="                        }" line267="                    }" line268="                }" line269="            }" line270="            basic.pause(1)" line271="        }" line272="        draw()" line273="    }" line274="    /**" line275="     * Image map of 32x16." line276="     */" line277="    //% block=&quot;image: 32x16&quot;" line278="    //% advanced=true" line279="    //% shim=images::createImage" line280="    //% imageLiteral=1 imageLiteralRows=16 imageLiteralColumns=32" line281="    export function imageMapL(leds: string): Image {" line282="        return &lt;Image&gt;&lt;any&gt;leds" line283="    }" line284="    /**" line285="     * Image map of 16x8." line286="     */" line287="    //% block=&quot;image: 16x8&quot;" line288="    //% shim=images::createImage" line289="    //% imageLiteral=1 imageLiteralRows=8 imageLiteralColumns=16" line290="    export function imageMapS(leds: string): Image {" line291="        return &lt;Image&gt;&lt;any&gt;leds" line292="    }" line293="}" numlines="294"></mutation></block></statement></block></xml>