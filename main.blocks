ne43="    function getbit(bits: number, shift: number): number {" line44="        return (bits &gt;&gt; shift) &amp; 1;" line45="    }" line46="    /**" line47="     * Initialize OLED display, this command must be called at the start of the program." line48="     */" line49="    //% block=&quot;init OLED display&quot;" line50="    //% weight=101" line51="    export function init(): void {" line52="        screen = pins.createBuffer(1025)" line53="        cmd1(0xAE)" line54="        cmd1(0xA4)" line55="        cmd2(0xD5, 0xF0)" line56="        cmd2(0xA8, 0x3F)" line57="        cmd2(0xD3, 0x00)" line58="        cmd1(0x0)" line59="        cmd2(0x8D, 0x14)" line60="        cmd2(0x20, 0x00)" line61="        cmd3(0x21, 0x0, 0x7F)" line62="        cmd3(0x22, 0x0, 0x3F)" line63="        cmd1(0xa1)" line64="        cmd1(0xC8)" line65="        cmd2(0xDA, 0x12)" line66="        cmd2(0x81, 0xFF)" line67="        cmd2(0xD9, 0xF1)" line68="        cmd2(0xDB, 0x40)" line69="        cmd1(0xA6)" line70="        cmd2(0xD6, 0x0)" line71="        cmd1(0xAF)" line72="        clear()" line73="        draw()" line74="    }" line75="    /**" line76="     * Clears screen" line77="     */" line78="    //% block=&quot;clear&quot;" line79="    //% weight=99" line80="    export function clear(): void {" line81="        screen.fill(0)" line82="    }" line83="    /**" line84="    */" line85="    //% block=&quot;draw&quot;" line86="    //% weight=98" line87="    function draw(): void {" line88="        pins.i2cWriteNumber(ADDR, 0xB0, NumberFormat.UInt16BE)" line89="        pins.i2cWriteNumber(ADDR, 0x00, NumberFormat.UInt16BE)" line90="        pins.i2cWriteNumber(ADDR, 0x10, NumberFormat.UInt16BE)" line91="        screen[0] = 0x40" line92="        pins.i2cWriteBuffer(ADDR, screen, false)" line93="    }" line94="    /**" line95="     * Sets pixel at x y to on." line96="     * @param x coordinate x (increases towards the right)" line97="     * @param y coordinate y (increases downwards)" line98="   